# Copy to ~/.seedleak/env or export in your shell. NEVER commit real tokens.
# Create at: https://github.com/settings/tokens
# Recommended classic scopes: public_repo (issues on public repos)
# Optional: security events / advisory reporting as available for your account.

GITHUB_TOKEN=ghp_replace_me_after_revoking_any_leaked_token

# Optional override for case DB + HMAC secret location
# SEEDLEAK_HOME=/path/to/.seedleak
